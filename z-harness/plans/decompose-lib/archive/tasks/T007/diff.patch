+                        // Reconfigure the surface and skip this frame
+                        self.surface.configure(&self.device, &self.config);
+                        return Ok(());
+                    }
+                    wgpu::SurfaceError::OutOfMemory => {
+                        return Err(e);
+                    }
+                    wgpu::SurfaceError::Timeout => {
+                        // Skip this frame and try again on the next one
+                        return Ok(());
+                    }
+                }
+            }
+        };
